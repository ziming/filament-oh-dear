{
    "name": "ziming/filament-oh-dear",
    "description": "A read-only Filament panel plugin for Oh Dear monitor insights.",
    "keywords": [
        "laravel",
        "filament",
        "filament-plugin",
        "oh-dear",
        "monitoring"
    ],
    "homepage": "https://github.com/ziming/filament-oh-dear",
    "license": "MIT",
    "authors": [
        {
            "name": "ziming",
            "email": "ziming.opensource@gmail.com",
            "role": "Package Uploader"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^5",
        "illuminate/contracts": "^12.0|^13.0",
        "ohdearapp/ohdear-php-sdk": "^4",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "nunomaduro/collision": "^8.9",
        "orchestra/testbench": "^10.0|^11.0",
        "orchestra/workbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ziming\\FilamentOhDear\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ziming\\FilamentOhDear\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ziming\\FilamentOhDear\\FilamentOhDearServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
